# @pinagent/cloud-dashboard — local env contract (NOT real values).
#
# Next.js reads `.env.local` (this file's uncommitted sibling) into process.env.
# Copy this to `.env.local` and adjust, or run via Doppler:
#
#   doppler run --config dev -- pnpm --filter @pinagent/cloud-dashboard dev
#
# Keys mirror the `process.env` reads in next.config.ts. Keep in sync —
# enforced by `pnpm lint:env-example`.

# Origin of the control-plane Worker (apps/cloud) the dashboard proxies to.
# Defaults to the local `wrangler dev` origin when unset; set to the deployed
# control plane in production.
CLOUD_API_ORIGIN=http://127.0.0.1:8787
