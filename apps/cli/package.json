{
  "name": "@pinagent/cli",
  "version": "0.0.2",
  "private": true,
  "description": "Pinagent CLI: thin wrapper around the OSS packages. `pinagent init`, `pinagent mcp`, `pinagent list`, `pinagent resolve`, `pinagent transcript`.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "pinagent": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pinagent/mcp": "workspace:*",
    "@pinagent/shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pinagent/agent-runner": "workspace:*",
    "@pinagent/vite-plugin": "workspace:*",
    "@types/node": "^22.10.1",
    "nanoid": "^5.0.9",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
