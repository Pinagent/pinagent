{
  "name": "@pinagent/cli",
  "version": "0.2.6",
  "description": "Pinagent CLI: thin wrapper around the OSS packages. `pinagent init`, `pinagent mcp`, `pinagent transcript`.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "pinagent": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsdown"
  },
  "dependencies": {
    "@pinagent/mcp": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pinagent/agent-runner": "workspace:*",
    "@pinagent/shared": "workspace:*",
    "@pinagent/vite-plugin": "workspace:*",
    "@types/node": "^25.9.1",
    "nanoid": "^5.0.9",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
