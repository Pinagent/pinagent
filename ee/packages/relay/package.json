{
  "name": "@pinagent/ee-relay",
  "version": "0.0.0",
  "private": true,
  "description": "Hosted multi-tenant relay between developer machines and the cloud agent runtime.",
  "license": "Elastic-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:worker": "wrangler dev --var RELAY_ALLOW_INSECURE:true",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pinagent/ee-auth": "workspace:*",
    "@pinagent/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.96.0"
  }
}
