{
  "name": "@pinagent/babel-plugin",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Babel transform that injects data-pa-loc (source file:line) attributes onto JSX elements at build time, plus the matching webpack loader.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./loader": "./dist/loader.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
