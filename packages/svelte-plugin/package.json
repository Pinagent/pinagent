{
  "name": "@pinagent/svelte-plugin",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Proof-of-concept: Svelte component markup transform that injects data-pa-loc (source file:line:col) attributes onto elements at build time. The Svelte analogue of @pinagent/babel-plugin for JSX and @pinagent/vue-plugin for SFCs.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "dependencies": {
    "svelte": "^5.56.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
