{
  "name": "@pinagent/widget-dock",
  "version": "0.3.0",
  "license": "Apache-2.0",
  "description": "Pinagent dock surface — project-management UI complementing the per-element widget. Loaded into host pages by @pinagent/vite-plugin and @pinagent/next-plugin when `dock: true` is passed.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "packages/widget-dock"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "predev": "pnpm exec turbo run build --filter=@pinagent/widget",
    "dev": "vite",
    "prebuild": "pnpm exec turbo run build --filter=@pinagent/widget",
    "build": "vite build --base=/__pinagent/dock/",
    "preview": "vite preview",
    "pretypecheck": "pnpm exec turbo run build --filter=@pinagent/widget-dock^...",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6008 --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@pinagent/shared": "workspace:*",
    "@pinagent/ui": "workspace:*",
    "@pinagent/widget": "workspace:*",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "zod": "^4.4.3"
  }
}
