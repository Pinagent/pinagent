{
  "name": "@pinagent/widget",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Pinagent browser widget (shadow-root pick + composer). Built as IIFE and consumed by @pinagent/vite-plugin.",
  "main": "dist/widget.iife.js",
  "exports": {
    ".": "./dist/widget.iife.js",
    "./iife": "./dist/widget.iife.js",
    "./brand": {
      "types": "./dist/brand.d.ts",
      "import": "./dist/brand.js",
      "require": "./dist/brand.cjs"
    },
    "./logo": {
      "types": "./dist/logo.d.ts",
      "import": "./dist/logo.js",
      "require": "./dist/logo.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6007 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@pinagent/db": "workspace:*",
    "@pinagent/shared": "workspace:*",
    "@pinagent/ui": "workspace:*",
    "@sqlite.org/sqlite-wasm": "3.50.0-build1",
    "drizzle-orm": "^0.45.2",
    "html-to-image": "^1.11.13"
  },
  "devDependencies": {
    "@storybook/html-vite": "^10.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.15",
    "better-sqlite3": "^12.10.0",
    "react": "^19.2.6",
    "storybook": "^10.4.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
