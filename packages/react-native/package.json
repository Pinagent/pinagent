{
  "name": "@pinagent/react-native",
  "version": "0.2.5",
  "license": "Apache-2.0",
  "description": "React Native & Expo plugin for Pinagent — tap a view, leave a comment, and a coding agent fixes it with file:line + a screenshot. The native widget ships as source for Metro; the dev-server middleware and Babel source-tagging plugin are built for Node.",
  "keywords": [
    "react-native",
    "expo",
    "metro",
    "pinagent",
    "claude",
    "ai-agent",
    "feedback",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "packages/react-native"
  },
  "homepage": "https://github.com/Pinagent/pinagent/tree/main/packages/react-native#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/native/index.d.ts",
      "react-native": "./src/native/index.ts",
      "default": "./src/native/index.ts"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./babel": {
      "types": "./dist/babel.d.ts",
      "import": "./dist/babel.js",
      "require": "./dist/babel.cjs"
    }
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "src/native",
    "drizzle"
  ],
  "scripts": {
    "prebuild": "node scripts/copy-drizzle.mjs",
    "build": "tsdown && tsc -p tsconfig.native.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.native.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-svg": ">=13",
    "react-native-view-shot": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "react-native-view-shot": {
      "optional": true
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.181",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.0.9",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pinagent/agent-runner": "workspace:*",
    "@pinagent/db": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
