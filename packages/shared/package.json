{
  "name": "@pinagent/shared",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Shared types, zod schemas, and constants used across Pinagent packages.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
