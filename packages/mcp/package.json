{
  "name": "@pinagent/mcp",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "description": "stdio MCP server for Pinagent — exposes pending feedback, screenshots, and source context to a coding agent.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "pinagent-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepare": "tsdown"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@pinagent/db": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.38.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
