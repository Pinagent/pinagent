{
  "name": "@pinagent/mcp",
  "version": "0.0.1",
  "description": "stdio MCP server for Pinagent — exposes pending feedback, screenshots, and source context to a coding agent.",
  "type": "module",
  "bin": {
    "pinagent-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@pinagent/db": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.38.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
