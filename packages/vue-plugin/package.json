{
  "name": "@pinagent/vue-plugin",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Proof-of-concept: Vue SFC <template> transform that injects data-pa-loc (source file:line:col) attributes onto template elements at build time. The Vue analogue of @pinagent/babel-plugin for JSX.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/compiler-core": "^3.5.13",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue": "^3.5.13"
  }
}
