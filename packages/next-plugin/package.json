{
  "name": "@pinagent/next-plugin",
  "version": "0.0.20",
  "license": "Apache-2.0",
  "description": "Next.js plugin for Pinagent — capture in-browser UI feedback with file:line and a screenshot, hand it to your coding agent over MCP.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "packages/next-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "production": {
        "import": "./dist/index-noop.js",
        "require": "./dist/index-noop.cjs"
      },
      "default": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "production": {
        "import": "./dist/config-noop.js",
        "require": "./dist/config-noop.cjs"
      },
      "default": {
        "import": "./dist/config.js",
        "require": "./dist/config.cjs"
      }
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "production": {
        "import": "./dist/route-noop.js",
        "require": "./dist/route-noop.cjs"
      },
      "default": {
        "import": "./dist/route.js",
        "require": "./dist/route.cjs"
      }
    },
    "./loader": "./dist/loader.cjs"
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "prebuild": "node scripts/embed-widget.mjs && node scripts/copy-drizzle.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@sqlite.org/sqlite-wasm": "^3.50.0-build1",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.38.0",
    "nanoid": "^5.0.9",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pinagent/agent-runner": "workspace:*",
    "@pinagent/babel-plugin": "workspace:*",
    "@pinagent/browser-runtime": "workspace:*",
    "@pinagent/db": "workspace:*",
    "@pinagent/shared": "workspace:*",
    "@pinagent/widget": "workspace:*",
    "@types/babel__traverse": "^7.20.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.15",
    "@types/ws": "^8.18.1",
    "next": "^16.0.0",
    "react": "^19.2.6",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
