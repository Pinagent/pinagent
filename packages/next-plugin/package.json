{
  "name": "@pinagent/next-plugin",
  "version": "0.0.20",
  "license": "Apache-2.0",
  "description": "Next.js adapter for Pinagent: webpack loader for JSX tagging, route handlers for /__pinagent/*, and a <Pinagent /> widget component.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "packages/next-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "production": {
        "import": "./dist/index-noop.js",
        "require": "./dist/index-noop.cjs"
      },
      "default": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "production": {
        "import": "./dist/config-noop.js",
        "require": "./dist/config-noop.cjs"
      },
      "default": {
        "import": "./dist/config.js",
        "require": "./dist/config.cjs"
      }
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "production": {
        "import": "./dist/route-noop.js",
        "require": "./dist/route-noop.cjs"
      },
      "default": {
        "import": "./dist/route.js",
        "require": "./dist/route.cjs"
      }
    },
    "./loader": "./dist/loader.cjs"
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "prebuild": "node scripts/embed-widget.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "drizzle:gen": "drizzle-kit generate",
    "drizzle:check": "drizzle-kit check"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "dependencies": {
    "@pinagent/agent-runner": "workspace:*",
    "@pinagent/babel-plugin": "workspace:*",
    "@pinagent/db": "workspace:*",
    "@pinagent/shared": "workspace:*",
    "@sqlite.org/sqlite-wasm": "^3.50.0-build1",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@pinagent/widget": "workspace:*",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.15",
    "drizzle-kit": "^0.31.10",
    "next": "^16.0.0",
    "react": "^19.2.6",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
