{
  "name": "@pinagent/nuxt-plugin",
  "version": "0.1.7",
  "license": "Apache-2.0",
  "description": "Nuxt module for Pinagent — click a UI element in your Nuxt dev server, leave a comment, and hand it to a coding agent with file:line and a screenshot.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "packages/nuxt-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/module.cjs",
  "module": "dist/module.js",
  "types": "dist/module.d.ts",
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js",
      "require": "./dist/module.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0",
    "@pinagent/vite-plugin": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
