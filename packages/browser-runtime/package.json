{
  "name": "@pinagent/browser-runtime",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "In-browser runtime: SQLite-WASM cache, iframe lifecycle, HMR re-anchoring. Loaded into the host page by @pinagent/vite-plugin and @pinagent/next-plugin.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
