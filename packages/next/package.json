{
  "name": "@pinpoint/next",
  "version": "0.0.16",
  "description": "Next.js adapter for Pinpoint: webpack loader for JSX tagging, route handlers for /__pinpoint/*, and a <Pinpoint /> widget component.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "import": "./dist/route.js",
      "require": "./dist/route.cjs"
    },
    "./loader": "./dist/loader.cjs"
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "node scripts/embed-widget.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.26.3",
    "nanoid": "^5.0.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pinpoint/widget": "workspace:*",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
