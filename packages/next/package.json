{
  "name": "@pinagent/next",
  "version": "0.0.20",
  "description": "Next.js adapter for Pinagent: webpack loader for JSX tagging, route handlers for /__pinagent/*, and a <Pinagent /> widget component.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "production": {
        "import": "./dist/index-noop.js",
        "require": "./dist/index-noop.cjs"
      },
      "default": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "production": {
        "import": "./dist/config-noop.js",
        "require": "./dist/config-noop.cjs"
      },
      "default": {
        "import": "./dist/config.js",
        "require": "./dist/config.cjs"
      }
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "production": {
        "import": "./dist/route-noop.js",
        "require": "./dist/route-noop.cjs"
      },
      "default": {
        "import": "./dist/route.js",
        "require": "./dist/route.cjs"
      }
    },
    "./loader": "./dist/loader.cjs"
  },
  "files": ["dist", "drizzle"],
  "scripts": {
    "prebuild": "node scripts/embed-widget.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "drizzle:gen": "drizzle-kit generate",
    "drizzle:check": "drizzle-kit check"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.29.7",
    "@pinagent/db": "workspace:*",
    "@sqlite.org/sqlite-wasm": "^3.50.0-build1",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.38.0",
    "nanoid": "^5.0.9",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pinagent/widget": "workspace:*",
    "@types/babel__traverse": "^7.20.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
