{
  "name": "@pinagent/vite-plugin",
  "version": "0.9.0",
  "license": "Apache-2.0",
  "description": "Vite plugin for Pinagent — capture in-browser UI feedback with file:line and a screenshot, hand it to your coding agent over MCP.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pinagent/pinagent.git",
    "directory": "packages/vite-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "prebuild": "node scripts/embed-widget.mjs && node scripts/copy-drizzle.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "pretypecheck": "node scripts/embed-widget.mjs",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.161",
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@pinagent/widget-dock": "workspace:*",
    "@sqlite.org/sqlite-wasm": "3.50.0-build1",
    "@vue/compiler-sfc": "^3.5.13",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.0.9",
    "svelte": "^5.56.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pinagent/agent-runner": "workspace:*",
    "@pinagent/babel-plugin": "workspace:*",
    "@pinagent/browser-runtime": "workspace:*",
    "@pinagent/db": "workspace:*",
    "@pinagent/next-plugin": "workspace:*",
    "@pinagent/shared": "workspace:*",
    "@pinagent/svelte-plugin": "workspace:*",
    "@pinagent/vue-plugin": "workspace:*",
    "@pinagent/widget": "workspace:*",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
