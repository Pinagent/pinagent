{
  "name": "@pinpoint/vite-plugin",
  "version": "0.0.1",
  "description": "Vite plugin for Pinpoint: tags JSX with file:line, injects the widget, serves /__pinpoint middleware.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "node scripts/embed-widget.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7"
  },
  "dependencies": {
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.26.3",
    "nanoid": "^5.0.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pinpoint/widget": "workspace:*",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
