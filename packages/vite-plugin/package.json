{
  "name": "@pinagent/vite-plugin",
  "version": "0.0.2",
  "description": "Vite plugin for Pinagent: tags JSX with file:line, injects the widget, serves /__pinagent middleware.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node scripts/embed-widget.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "nanoid": "^5.0.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pinagent/widget": "workspace:*",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  }
}
