node_modules
dist
.pinagent
# Claude Code's local agent worktrees — linked git checkouts, never committed.
# Leaving them visible let `git add -A` (the dashboard's auto-commit) record
# each as a submodule gitlink and spam PRs with `.claude/worktrees/*` entries,
# and made the working-copy "uncommitted" state inaccurate. (.claude/skills
# stays tracked.)
.claude/worktrees/
# generated by packages/{next-plugin,vite-plugin}/scripts/copy-drizzle.mjs
# (source of truth is packages/db/drizzle/)
packages/next-plugin/drizzle
packages/vite-plugin/drizzle

# generated by packages/{next-plugin,vite-plugin}/scripts/embed-widget.mjs
# (source of truth is packages/widget/dist/widget.iife.js — built by @pinagent/widget)
# Regenerated by the plugins' prebuild + pretypecheck + the root pretest.
packages/next-plugin/src/__generated__
packages/vite-plugin/src/__generated__
.DS_Store
*.log
.turbo
# V8 compile cache (NODE_COMPILE_CACHE) written under packages during install/run
**/node-compile-cache
.next
*.tsbuildinfo
coverage
storybook-static
.cache
node-compile-cache
.env
.env.*
!.env.example
# Cloudflare Workers local secrets (wrangler reads .dev.vars, not .env). NOT
# matched by the .env.* rules above, so list it explicitly or it leaks.
.dev.vars
.dev.vars.*
!.dev.vars.example

# Node.js compile cache emitted by tsdown/node:sqlite builds
node-compile-cache/

# React Email preview client (generated by `email dev`)
ee/packages/email/.react-email
