{
  "name": "pinagent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:oss": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev --filter='./packages/*'",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:deps": "sherif --ignore-package react-vite-example --ignore-package next-app-example --ignore-package nuxt-app-example --ignore-package sveltekit-app-example",
    "lint:deps:fix": "sherif --fix --ignore-package react-vite-example --ignore-package next-app-example --ignore-package nuxt-app-example --ignore-package sveltekit-app-example",
    "lint:spdx": "node scripts/check-spdx.mjs",
    "lint:max-lines": "node scripts/check-max-lines.mjs",
    "lint:widget-cascade": "node scripts/widget-cascade-check.mjs",
    "lint:workspace-deps": "node scripts/check-workspace-deps.mjs",
    "lint:published-deps": "node scripts/check-published-deps.mjs",
    "lint:undeclared-imports": "node scripts/check-undeclared-imports.mjs",
    "lint:env-example": "node scripts/check-env-example.mjs",
    "lint:peer-deps": "pnpm install --frozen-lockfile --offline --strict-peer-dependencies",
    "format": "biome format --write .",
    "generate:plugin-widget-embed": "node packages/vite-plugin/scripts/embed-widget.mjs && node packages/next-plugin/scripts/embed-widget.mjs",
    "pretest": "pnpm generate:plugin-widget-embed",
    "test": "vitest run",
    "pretest:watch": "pnpm generate:plugin-widget-embed",
    "test:watch": "vitest",
    "pretest:coverage": "pnpm generate:plugin-widget-embed",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:preflight": "node scripts/check-release-preflight.mjs",
    "release:smoke": "node scripts/smoke-install-published.mjs",
    "release": "pnpm build:oss && pnpm release:preflight && changeset publish && pnpm release:smoke",
    "example": "pnpm --filter=react-vite-example dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.27.10",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.9.0",
    "sherif": "^1.12.0",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.14.0"
}
