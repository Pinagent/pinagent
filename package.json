{
  "name": "pinagent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:oss": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev --filter='./packages/*'",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:deps": "sherif --ignore-package react-vite-example --ignore-package next-app-example",
    "lint:deps:fix": "sherif --fix --ignore-package react-vite-example --ignore-package next-app-example",
    "lint:spdx": "node scripts/check-spdx.mjs",
    "lint:widget-cascade": "node scripts/widget-cascade-check.mjs",
    "lint:workspace-deps": "node scripts/check-workspace-deps.mjs",
    "lint:undeclared-imports": "node scripts/check-undeclared-imports.mjs",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:oss && changeset publish",
    "example": "pnpm --filter=react-vite-example dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.27.10",
    "happy-dom": "^20.9.0",
    "sherif": "^1.6.0",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.14.0"
}
